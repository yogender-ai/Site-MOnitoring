# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/sitemonitoring

# Secret for signing JWTs (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# Server port (optional, default 5000)
PORT=5000

# Optional: external URL for keep-alive self-ping (e.g. on Render)
# RENDER_EXTERNAL_URL=https://your-app.onrender.com
# SELF_URL=http://localhost:5000
